global:
  scrape_interval: 30s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090

{# LibreSpeed bandwidth metrics arrive via the node-exporter textfile collector,
   so there is no dedicated scrape job here. #}
{% if blackbox_exporter_enabled | bool %}
  # Continuous ICMP probes via blackbox-exporter. Targets are passed to the
  # exporter and the address is rewritten to the exporter itself.
  - job_name: blackbox-icmp
    scrape_interval: {{ blackbox_scrape_interval }}
    metrics_path: /probe
    params:
      module: [icmp]
    static_configs:
      - targets:
{% for target in blackbox_probe_targets %}
          - {{ target }}
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
{% endif %}

{% if cadvisor_enabled | bool %}
  - job_name: cadvisor
    static_configs:
      - targets:
          - cadvisor:8080
{% endif %}

{% if node_exporter_enabled | bool %}
  - job_name: node-exporter
    static_configs:
      - targets:
          - node-exporter:9100
{% endif %}
