# OS
.DS_Store

# Ansible
*.retry
*.log
# Vault password file — NEVER commit. The encrypted vault.yml itself IS committed.
.vault_pass
.vault_pass.txt
vault_pass*

# Local inventory (contains real host IPs / users) — commit hosts.yml.example instead
inventory/hosts.yml

# Editor / tool backups (vault.yml.save etc. may contain plaintext secrets!)
*.save
*~
*.swp
*.orig
*.bak

# Python / virtualenv (if used locally)
.venv/
venv/
__pycache__/
*.pyc

# Stray virtualenv dirs created by mangled shell commands — keep them out
/#/
/conda/
/python,/

# Molecule / test artifacts
.molecule/
.cache/
.pytest_cache/

# Galaxy-installed collections/roles (pinned via requirements.yml instead)
collections/
roles/galaxy/
