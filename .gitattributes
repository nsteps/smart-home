# GitHub Linguist language detection.
# This is an Ansible/YAML project; Jinja2 templates render YAML/conf, so count
# them as YAML instead of letting them skew the repo's primary language.
*.j2 linguist-language=YAML
*.yml linguist-language=YAML
*.yaml linguist-language=YAML

# Keep meta files out of the language statistics.
*.cfg linguist-language=INI
molecule/** linguist-detectable=false
.github/** linguist-detectable=false
